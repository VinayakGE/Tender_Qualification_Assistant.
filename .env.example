# Copy this file to .env and fill in your values.
# The pipeline runs without ANTHROPIC_API_KEY — LLM stages use fallbacks.

# Required for LLM extraction and explanation (optional for Milestone 0)
# ANTHROPIC_API_KEY=sk-ant-...

# Model (default: claude-sonnet-4-6)
# MODEL=claude-sonnet-4-6

# Logging: json (machine-readable) or console (human-readable)
# LOG_FORMAT=console
# LOG_LEVEL=INFO

# Thresholds (tunable without code changes)
# QUALIFICATION_PASS_THRESHOLD=80
# QUALIFICATION_MARGINAL_THRESHOLD=60
# INCUMBENT_RISK_HIGH_THRESHOLD=70
